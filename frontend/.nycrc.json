{
  "all": true,
  "include": ["src/**/*.{js,vue}"],
  "exclude": [
    "tests/**",
    "cypress/**",
    "dist/**",
    "node_modules/**",
    "src/main.js",
    "src/router/**",
    "src/db/seed.js",
    "src/db/seedData.js"
  ],
  "extension": [".js", ".vue"],
  "reporter": ["text-summary", "lcov", "html", "json-summary"],
  "report-dir": "coverage",
  "temp-dir": ".nyc_output"
}
